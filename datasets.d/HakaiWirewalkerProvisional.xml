<dataset type="EDDTableFromParquetFiles" datasetID="HakaiWirewalkerProvisional" active="true">
    <fileDir>/datasets/HakaiWirewalkerProvisional/</fileDir>
    <fileNameRegex>.*\.parquet</fileNameRegex>
    <recursive>true</recursive>
    <pathRegex>.*</pathRegex>
    <metadataFrom>last</metadataFrom>
    <fileTableInMemory>false</fileTableInMemory>
    <accessibleViaFiles>true</accessibleViaFiles>
    <reloadEveryNMinutes>1440</reloadEveryNMinutes>
    <updateEveryNMillis>10000</updateEveryNMillis>
    <addAttributes>
        <att name="Conventions">COARDS, CF-1.6, ACDD-1.3</att>
        <att name="institution">Hakai Institute</att>
        <att name="license">https://creativecommons.org/licenses/by/4.0</att>
        <att name="standard_name_vocabulary">CF Standard Name Table v79</att>
        <att name="cdm_data_type">TimeSeries</att>
        <att name="cdm_timeseries_variables">serial_number, latitude, longitude</att>
        <att name="subsetVariables">serial_number, latitude, longitude</att>
        <att name="title">Water Property Measurements from the Bute Inlet Ocean Observing Station (BIOOS) Wirewalker, Bute Inlet, BC, Canada (Provisional)</att>
        <att name="summary">Provisional Wirewalker oceanographic data from the Hakai Institute. This dataset has not been fully quality controlled.</att>
        <att name="infoUrl">https://www.hakai.org</att>
        <att name="sourceUrl">(local files)</att>
        <att name="geospatial_lat_max">50.5744</att>
        <att name="geospatial_lat_min">50.5744</att>
        <att name="geospatial_lon_max">-124.9009</att>
        <att name="geospatial_lon_min">-124.9009</att>
    </addAttributes>
    <dataVariable>
        <sourceName>serial_number</sourceName>
        <destinationName>serial_number</destinationName>
        <dataType>int</dataType>
        <addAttributes>
            <att name="long_name">Serial Number</att>
            <att name="cf_role">timeseries_id</att>
            <att name="ioos_category">Identifier</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>=50.5744</sourceName>
        <destinationName>latitude</destinationName>
        <dataType>float</dataType>
        <addAttributes>
            <att name="long_name">Latitude</att>
            <att name="standard_name">latitude</att>
            <att name="units">degrees_north</att>
            <att name="description">Fixed latitude of the deployment site</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>=-124.9009</sourceName>
        <destinationName>longitude</destinationName>
        <dataType>float</dataType>
        <addAttributes>
            <att name="long_name">Longitude</att>
            <att name="standard_name">longitude</att>
            <att name="units">degrees_east</att>
            <att name="description">Fixed longitude of the deployment site</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>datetime_utc</sourceName>
        <destinationName>time</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="ioos_category">Time</att>
            <att name="long_name">Time</att>
            <att name="standard_name">time</att>
            <att name="units">milliseconds since 1970-01-01T00:00:00Z</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>Conductivity (mS/cm)</sourceName>
        <destinationName>conductivity</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="long_name">Conductivity</att>
            <att name="standard_name">sea_water_electrical_conductivity</att>
            <att name="units">mS/cm</att>
            <att name="ioos_category">Salinity</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>Temperature (°C)</sourceName>
        <destinationName>temperature</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="long_name">Temperature</att>
            <att name="standard_name">sea_water_temperature</att>
            <att name="units">degree_Celsius</att>
            <att name="ioos_category">Temperature</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>Pressure (dbar)</sourceName>
        <destinationName>pressure</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="long_name">Pressure</att>
            <att name="standard_name">sea_water_pressure</att>
            <att name="units">dbar</att>
            <att name="ioos_category">Pressure</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>Temperature 1 (°C)</sourceName>
        <destinationName>temperature_1</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="long_name">Temperature 1</att>
            <att name="standard_name">sea_water_temperature</att>
            <att name="units">degree_Celsius</att>
            <att name="ioos_category">Temperature</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>Dissolved O₂ concentration (µmol/l)</sourceName>
        <destinationName>dissolved_o2</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="long_name">Dissolved O2 Concentration</att>
            <att name="standard_name">moles_of_oxygen_per_unit_mass_in_sea_water</att>
            <att name="units">umol/L</att>
            <att name="ioos_category">Dissolved O2</att>
        </addAttributes>
    </dataVariable>
    <dataVariable>
        <sourceName>Time (ms)</sourceName>
        <destinationName>time_ms</destinationName>
        <dataType>double</dataType>
        <addAttributes>
            <att name="long_name">Time (ms)</att>
            <att name="units">ms</att>
            <att name="ioos_category">Time</att>
            <att name="comment">Raw instrument timestamp in milliseconds, retained for traceability.</att>
        </addAttributes>
    </dataVariable>
</dataset>
